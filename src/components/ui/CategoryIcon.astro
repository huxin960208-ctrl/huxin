---
import type { Category } from '../../types';

export interface Props {
  category: Category;
  size?: 'sm' | 'md';
}

const { category, size = 'md' } = Astro.props;

const colors: Record<Category, string> = {
  'car-accidents': '#b8944c',
  'slip-and-fall': '#b8944c',
  'medical-malpractice': '#b8944c',
  'workplace-injuries': '#b8944c',
  'wrongful-death': '#b8944c',
};

const dim = size === 'sm' ? 8 : 10;
---

<svg width={dim} height={dim} viewBox="0 0 10 10" aria-hidden="true" class="flex-shrink-0">
  <circle cx="5" cy="5" r="5" fill={colors[category]} />
</svg>
