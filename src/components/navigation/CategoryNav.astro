---
import { CATEGORY_MAP, type Category } from '../../types';
export interface Props { categories: Category[]; selected?: Category; }
const { categories, selected } = Astro.props;
---

<nav aria-label="Category navigation" class="overflow-x-auto">
  <ul class="flex gap-2 whitespace-nowrap pb-1">
    {categories.map(cat => {
      const info = CATEGORY_MAP[cat];
      const isActive = cat === selected;
      return (
        <li>
          <a href={`/categories/${cat}`} class={`inline-block px-4 py-2 text-sm font-medium rounded-xl no-underline transition-all duration-200 ${
            isActive ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'
          }`}>{info.title}</a>
        </li>
      );
    })}
  </ul>
</nav>
