---
import { CATEGORY_MAP, type Category } from '../../types';
import CategoryIcon from '../ui/CategoryIcon.astro';

export interface Props {
  categories: Category[];
  selected?: Category;
  articleCounts?: Record<Category, number>;
}

const { categories, selected } = Astro.props;
---

<nav aria-label="Category navigation" class="overflow-x-auto">
  <ul class="flex gap-1.5 whitespace-nowrap">
    {categories.map((cat) => {
      const info = CATEGORY_MAP[cat];
      const isActive = cat === selected;
      return (
        <li>
          <a
            href={`/categories/${cat}`}
            class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs md:text-sm font-medium no-underline transition-colors ${
              isActive
                ? 'bg-primary text-white'
                : 'bg-gray-100 text-primary hover:bg-gray-200'
            }`}
          >
            <CategoryIcon category={cat} size="sm" />
            <span>{info.title}</span>
          </a>
        </li>
      );
    })}
  </ul>
</nav>
