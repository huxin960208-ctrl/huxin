---
import { CATEGORY_MAP, type Category } from '../../types';

export interface Props {
  categories: Category[];
  selected?: Category;
}

const { categories, selected } = Astro.props;
---

<nav aria-label="Category navigation" class="overflow-x-auto">
  <ul class="flex gap-1 whitespace-nowrap">
    {categories.map((cat) => {
      const info = CATEGORY_MAP[cat];
      const isActive = cat === selected;
      return (
        <li>
          <a
            href={`/categories/${cat}`}
            class={`inline-block px-4 py-2 text-xs uppercase tracking-wider no-underline transition-colors font-label ${
              isActive
                ? 'bg-navy text-white'
                : 'text-navy/60 hover:text-navy border border-border hover:border-navy/30'
            }`}
          >
            {info.title}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
