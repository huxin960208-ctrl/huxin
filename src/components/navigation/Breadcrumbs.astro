---
export interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  ...items,
];
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-x-2 text-sm text-muted">
    {breadcrumbItems.map((item, i) => {
      const isLast = i === breadcrumbItems.length - 1;
      return (
        <li class="flex items-center gap-x-2">
          {i > 0 && (
            <svg class="w-3 h-3 text-muted/50 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
          )}
          {isLast || !item.href ? (
            <span class={isLast ? 'text-primary font-medium' : ''}>{item.label}</span>
          ) : (
            <a href={item.href} class="no-underline hover:text-primary transition-colors">
              {item.label}
            </a>
          )}
        </li>
      );
    })}
  </ol>
</nav>
