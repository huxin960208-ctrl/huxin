---
export interface Props { items: { label: string; href?: string }[]; }
const { items } = Astro.props;
const all = [{ label: 'Home', href: '/' }, ...items];
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol class="flex flex-wrap items-center gap-x-2 text-sm text-slate-400">
    {all.map((item, i) => {
      const isLast = i === all.length - 1;
      return (
        <li class="flex items-center gap-x-2">
          {i > 0 && <span aria-hidden="true" class="text-slate-300">/</span>}
          {isLast || !item.href ? <span class="text-slate-800 font-medium">{item.label}</span> : <a href={item.href} class="no-underline hover:text-slate-800 transition-colors">{item.label}</a>}
        </li>
      );
    })}
  </ol>
</nav>
