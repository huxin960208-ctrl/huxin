---
import { SITE, CATEGORY_MAP } from '../../types';
import MobileMenu from './MobileMenu.astro';

const currentPath = Astro.url.pathname;

function navLink(path: string, exact = false) {
  const active = exact ? currentPath === path : currentPath.startsWith(path);
  const base = 'no-underline px-3 py-2 text-sm font-medium rounded-md transition-colors';
  if (active) return `${base} text-white bg-white/15`;
  return `${base} text-white/70 hover:text-white hover:bg-white/10`;
}
---

<header class="bg-primary text-white sticky top-0 z-50 shadow-md">
  <div class="container-main">
    <nav class="flex items-center justify-between h-14 md:h-16" aria-label="Main navigation">
      <a
        href="/"
        class="text-white no-underline font-bold text-base md:text-lg tracking-tight hover:text-accent-light transition-colors flex items-center gap-2"
      >
        <span class="text-accent text-xl leading-none">⚖</span>
        <span>{SITE.name}</span>
      </a>

      <div class="hidden md:flex items-center gap-0.5">
        <a href="/" class={navLink('/', true)}>Home</a>
        <div class="relative group">
          <a href="/categories" class={navLink('/categories') + ' flex items-center gap-1'}>
            Categories
            <svg class="w-3 h-3 opacity-50" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
            </svg>
          </a>
          <div class="absolute top-full left-0 mt-1 bg-white text-gray-900 rounded-lg shadow-lg border border-border py-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            {Object.values(CATEGORY_MAP).map((cat) => (
              <a
                href={`/categories/${cat.slug}`}
                class="flex items-center gap-2 px-4 py-2 hover:bg-gray-50 text-sm no-underline text-gray-700 hover:text-primary transition-colors"
              >
                <span class="text-base leading-none">{cat.icon}</span>
                <span>{cat.title}</span>
              </a>
            ))}
          </div>
        </div>
        <a href="/articles" class={navLink('/articles')}>All Articles</a>
        <a href="/about" class={navLink('/about', true)}>About</a>
        <a href="/contact" class={navLink('/contact', true)}>Contact</a>
      </div>

      <MobileMenu />
    </nav>
  </div>
</header>
