---
import { SITE, CATEGORY_MAP } from '../../types';
---

<footer class="bg-slate-900 text-white mt-20">
  <div class="container-wide py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div>
        <a href="/" class="no-underline"><span class="font-display text-white text-xl font-bold">{SITE.name}</span></a>
        <p class="mt-4 text-slate-400 text-sm leading-relaxed">{SITE.tagline}. Free, in-depth guides on personal injury law.</p>
      </div>
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-5">Practice Areas</h3>
        <ul class="space-y-3">
          {Object.values(CATEGORY_MAP).map(cat => (
            <li><a href={`/categories/${cat.slug}`} class="text-slate-400 hover:text-white text-sm no-underline transition-colors">{cat.title}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-5">Resources</h3>
        <ul class="space-y-3">
          <li><a href="/articles" class="text-slate-400 hover:text-white text-sm no-underline transition-colors">All Insights</a></li>
          <li><a href="/categories" class="text-slate-400 hover:text-white text-sm no-underline transition-colors">Categories</a></li>
          <li><a href="/about" class="text-slate-400 hover:text-white text-sm no-underline transition-colors">About</a></li>
          <li><a href="/contact" class="text-slate-400 hover:text-white text-sm no-underline transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-5">Legal</h3>
        <ul class="space-y-3">
          <li><a href="/privacy" class="text-slate-400 hover:text-white text-sm no-underline transition-colors">Privacy Policy</a></li>
          <li><a href="/disclaimer" class="text-slate-400 hover:text-white text-sm no-underline transition-colors">Disclaimer</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-14 pt-8 border-t border-slate-800 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-xs mb-0">&copy; {new Date().getFullYear()} {SITE.name}.</p>
      <p class="text-slate-500 text-xs mb-0">Educational purposes only. Not legal advice.</p>
    </div>
  </div>
</footer>
