---
import { SITE, CATEGORY_MAP } from '../../types';
---

<footer class="bg-navy text-white/60 mt-20">
  <div class="container-wide py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <a href="/" class="no-underline">
          <span class="font-heading text-white text-xl font-bold tracking-tight">{SITE.name}</span>
        </a>
        <p class="mt-4 text-sm text-white/40 leading-relaxed max-w-sm">
          {SITE.tagline}. Free, in-depth guides on personal injury law for accident victims and their families.
        </p>
      </div>

      <div class="md:col-span-2">
        <h3 class="text-white text-xs uppercase tracking-[0.2em] mb-5 font-label">Practice Areas</h3>
        <ul class="space-y-3">
          {Object.values(CATEGORY_MAP).map((cat) => (
            <li>
              <a href={`/categories/${cat.slug}`} class="text-white/50 hover:text-gold text-sm no-underline transition-colors">
                {cat.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <h3 class="text-white text-xs uppercase tracking-[0.2em] mb-5 font-label">Resources</h3>
        <ul class="space-y-3">
          <li><a href="/articles" class="text-white/50 hover:text-gold text-sm no-underline transition-colors">All Insights</a></li>
          <li><a href="/categories" class="text-white/50 hover:text-gold text-sm no-underline transition-colors">Categories</a></li>
          <li><a href="/about" class="text-white/50 hover:text-gold text-sm no-underline transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-white/50 hover:text-gold text-sm no-underline transition-colors">Contact</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h3 class="text-white text-xs uppercase tracking-[0.2em] mb-5 font-label">Legal</h3>
        <ul class="space-y-3">
          <li><a href="/privacy" class="text-white/50 hover:text-gold text-sm no-underline transition-colors">Privacy Policy</a></li>
          <li><a href="/disclaimer" class="text-white/50 hover:text-gold text-sm no-underline transition-colors">Disclaimer</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/30 mb-0">
        &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.
      </p>
      <p class="text-xs text-white/30 mb-0 max-w-lg text-center md:text-right leading-relaxed">
        This website provides general information for educational purposes only and does not constitute legal advice.
        No attorney-client relationship is created by using this site.
      </p>
    </div>
  </div>
</footer>
