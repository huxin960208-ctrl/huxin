---
import { SITE, CATEGORY_MAP } from '../../types';
---

<footer class="bg-primary text-white/70 mt-16">
  <div class="container-main py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="text-white no-underline font-bold text-lg flex items-center gap-2">
          <span class="text-accent text-xl leading-none">⚖</span>
          <span>{SITE.name}</span>
        </a>
        <p class="mt-3 text-sm text-white/50 leading-relaxed">{SITE.tagline}</p>
        <p class="mt-4 text-xs text-white/40">
          &copy; {new Date().getFullYear()} {SITE.name}
        </p>
      </div>

      <!-- Categories -->
      <div class="md:col-span-1">
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-4">Categories</h3>
        <ul class="space-y-2.5">
          {Object.values(CATEGORY_MAP).map((cat) => (
            <li>
              <a
                href={`/categories/${cat.slug}`}
                class="text-white/50 hover:text-white text-sm no-underline transition-colors"
              >
                {cat.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Pages -->
      <div class="md:col-span-1">
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-4">Pages</h3>
        <ul class="space-y-2.5">
          <li><a href="/articles" class="text-white/50 hover:text-white text-sm no-underline transition-colors">All Articles</a></li>
          <li><a href="/about" class="text-white/50 hover:text-white text-sm no-underline transition-colors">About</a></li>
          <li><a href="/contact" class="text-white/50 hover:text-white text-sm no-underline transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="md:col-span-1">
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2.5">
          <li><a href="/privacy" class="text-white/50 hover:text-white text-sm no-underline transition-colors">Privacy Policy</a></li>
          <li><a href="/disclaimer" class="text-white/50 hover:text-white text-sm no-underline transition-colors">Disclaimer</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 text-center text-xs text-white/40 leading-relaxed">
      <p>
        <strong class="text-white/60">Disclaimer:</strong> This website provides general information for educational purposes only.
        It does not constitute legal advice, nor does it create an attorney-client relationship.
        If you need legal assistance, please consult with a qualified personal injury attorney licensed in your state.
        This website may contain advertisements and may earn revenue from advertising.
      </p>
    </div>
  </div>
</footer>
