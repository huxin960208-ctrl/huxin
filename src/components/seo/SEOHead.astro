---
import { SITE } from '../../types';
import OrganizationSchema from './OrganizationSchema.astro';

export interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schemaScripts?: string;
}

const {
  title,
  description,
  canonicalURL,
  ogImage = `${SITE.url}${SITE.ogImage}`,
  ogType = 'website',
  noindex = false,
  schemaScripts = '',
} = Astro.props;

const pageTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta charset="UTF-8" />

<!-- Canonical -->
{canonicalURL && <link rel="canonical" href={canonicalURL} />}
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonicalURL || SITE.url} />
<meta property="og:site_name" content={SITE.name} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Font preloads -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- JSON-LD Schema -->
<OrganizationSchema />
{schemaScripts && <script type="application/ld+json" set:html={schemaScripts} />}
