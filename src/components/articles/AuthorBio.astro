---
export interface Props { author: string; bio?: string; }
const { author, bio } = Astro.props;
---

<div class="border-t border-slate-200 pt-8 mt-12 flex items-center gap-4">
  <div class="w-12 h-12 bg-gradient-to-br from-accent to-accent-dark rounded-full flex items-center justify-center text-white font-bold text-lg flex-shrink-0">{author.charAt(0)}</div>
  <div>
    <p class="text-sm font-semibold text-slate-900 mb-0.5">{author}</p>
    {bio && <p class="text-xs text-slate-500 mb-0">{bio}</p>}
  </div>
</div>
