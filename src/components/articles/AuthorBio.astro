---
export interface Props {
  author: string;
  bio?: string;
}

const { author, bio } = Astro.props;
---

<div class="border-t border-border pt-6 mt-10 flex items-center gap-4">
  <div class="w-10 h-10 bg-navy text-white flex items-center justify-center font-heading text-base flex-shrink-0">
    {author.charAt(0)}
  </div>
  <div>
    <p class="text-sm text-navy font-medium mb-0.5">{author}</p>
    {bio && <p class="text-xs text-muted mb-0">{bio}</p>}
  </div>
</div>
