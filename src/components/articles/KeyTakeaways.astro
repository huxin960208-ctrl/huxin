---
export interface Props { takeaways: string[]; }
const { takeaways } = Astro.props;
const show = takeaways && takeaways.length > 0;
---

{show && (
  <div class="bg-gradient-to-br from-accent/5 to-accent-dark/5 border border-accent/20 rounded-2xl p-6 my-8">
    <h3 class="text-sm font-bold text-slate-900 mb-4 mt-0 flex items-center gap-2">
      <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
      Key Takeaways
    </h3>
    <ul class="space-y-2.5 mb-0">
      {takeaways.map(point => (
        <li class="flex items-start gap-3 text-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-accent mt-2 flex-shrink-0"></span>
          <span class="text-slate-700">{point}</span>
        </li>
      ))}
    </ul>
  </div>
)}
