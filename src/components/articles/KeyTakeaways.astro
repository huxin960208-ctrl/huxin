---
export interface Props {
  takeaways: string[];
}

const { takeaways } = Astro.props;
const show = takeaways && takeaways.length > 0;
---

{show && (
  <div class="bg-cream border-l-2 border-gold p-5 my-8">
    <h3 class="font-label text-xs uppercase tracking-wider text-gold mb-3 mt-0">Key Takeaways</h3>
    <ul class="space-y-2 mb-0">
      {takeaways.map((point) => (
        <li class="flex items-start gap-2 text-sm">
          <span class="text-gold mt-0.5 flex-shrink-0">&mdash;</span>
          <span class="text-navy/80">{point}</span>
        </li>
      ))}
    </ul>
  </div>
)}
