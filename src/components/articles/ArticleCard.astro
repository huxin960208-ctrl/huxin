---
import { getArticleUrl, truncate } from '../../utils/urlUtils';
import ArticleMeta from './ArticleMeta.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { data, slug, body } = article;
---

<article class="card group h-full flex flex-col">
  {data.featuredImage && (
    <a href={getArticleUrl(slug)} class="block -mx-6 -mt-6 mb-4 overflow-hidden rounded-t-lg">
      <img
        src={data.featuredImage}
        alt={data.featuredImageAlt ?? data.title}
        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        width="600"
        height="300"
      />
    </a>
  )}
  <div class="flex-1 flex flex-col">
    <ArticleMeta
      pubDate={data.pubDate}
      category={data.category}
      author={data.author}
    >
      {/* The Meta component expects slot content - pass empty */}
      {body.slice(0, 100)}
    </ArticleMeta>
    <h3 class="text-lg md:text-xl mb-2 leading-snug">
      <a href={getArticleUrl(slug)} class="no-underline hover:text-primary-light transition-colors text-primary">
        {data.title}
      </a>
    </h3>
    <p class="text-muted text-sm md:text-base flex-1">
      {truncate(data.description, 140)}
    </p>
    {data.tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</article>
