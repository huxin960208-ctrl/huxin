---
import { getArticleUrl, truncate } from '../../utils/urlUtils';
import { getCategoryTitle, getCategoryUrl } from '../../utils/urlUtils';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { data, slug } = article;
---

<article class="group bg-white rounded-lg border border-border hover:border-primary/20 hover:shadow-sm transition-all duration-200 flex flex-col h-full">
  {data.featuredImage && (
    <a href={getArticleUrl(slug)} class="block overflow-hidden rounded-t-lg">
      <img
        src={data.featuredImage}
        alt={data.featuredImageAlt ?? data.title}
        class="w-full h-40 object-cover group-hover:scale-[1.03] transition-transform duration-300"
        loading="lazy"
        width="600"
        height="240"
      />
    </a>
  )}
  <div class="flex flex-col flex-1 p-5">
    <div class="flex items-center gap-2 mb-2.5">
      <a
        href={getCategoryUrl(data.category)}
        class="text-xs font-medium text-primary/60 no-underline hover:text-primary transition-colors"
      >
        {getCategoryTitle(data.category)}
      </a>
      <span class="text-border">|</span>
      <time datetime={data.pubDate.toISOString()} class="text-xs text-muted">
        {data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </time>
    </div>
    <h3 class="text-base md:text-lg font-bold mb-2 leading-snug flex-1">
      <a href={getArticleUrl(slug)} class="no-underline text-primary hover:text-primary-light transition-colors">
        {data.title}
      </a>
    </h3>
    <p class="text-sm text-muted leading-relaxed line-clamp-2">
      {truncate(data.description, 130)}
    </p>
  </div>
</article>
