---
import { getArticleUrl } from '../../utils/urlUtils';
import { getCategoryTitle } from '../../utils/urlUtils';
import type { CollectionEntry } from 'astro:content';

export interface Props { article: CollectionEntry<'articles'>; }
const { article } = Astro.props;
const { data, slug } = article;
---

<article class="group bg-white border border-slate-200 rounded-2xl overflow-hidden hover:border-slate-300 hover:shadow-xl hover:shadow-slate-900/5 transition-all duration-300 hover:-translate-y-1">
  {data.featuredImage && (
    <a href={getArticleUrl(slug)} class="block overflow-hidden">
      <img src={data.featuredImage} alt={data.featuredImageAlt ?? data.title} class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="312" />
    </a>
  )}
  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-semibold text-accent-dark bg-accent/10 px-2.5 py-0.5 rounded-full">{getCategoryTitle(data.category)}</span>
      <time datetime={data.pubDate.toISOString()} class="text-xs text-slate-400">{data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
    </div>
    <h3 class="text-lg font-bold leading-snug mb-2">
      <a href={getArticleUrl(slug)} class="no-underline text-slate-900 hover:text-accent-dark transition-colors">{data.title}</a>
    </h3>
    <p class="text-sm text-slate-500 leading-relaxed line-clamp-2 mb-0">{data.description}</p>
  </div>
</article>
