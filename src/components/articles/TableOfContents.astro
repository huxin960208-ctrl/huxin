---
import { slugify } from '../../utils/urlUtils';

export interface Props {
  headings: { depth: number; text: string }[];
}

const { headings } = Astro.props;

const filteredHeadings = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({
    ...h,
    id: slugify(h.text),
    indent: h.depth === 3,
  }));
---

{filteredHeadings.length > 0 && (
  <nav class="bg-white border border-border rounded-lg p-4 mb-8" aria-label="Table of Contents">
    <h2 class="text-sm font-bold uppercase tracking-wider text-muted mb-3">Table of Contents</h2>
    <ol class="space-y-1.5">
      {filteredHeadings.map((heading) => (
        <li class={heading.indent ? 'ml-4' : ''}>
          <a
            href={`#${heading.id}`}
            class="text-sm no-underline hover:text-primary-light text-muted transition-colors"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
