---
import { slugify } from '../../utils/urlUtils';

export interface Props {
  headings: { depth: number; text: string }[];
}

const { headings } = Astro.props;

const filtered = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({
    ...h,
    id: slugify(h.text),
    indent: h.depth === 3,
  }));
---

{filtered.length > 0 && (
  <nav class="bg-cream/50 border border-border p-5 mb-8" aria-label="Table of Contents">
    <h2 class="font-label text-xs uppercase tracking-wider text-muted mb-3 mt-0">In This Article</h2>
    <ol class="space-y-1.5">
      {filtered.map((h) => (
        <li class={h.indent ? 'ml-4' : ''}>
          <a
            href={`#${h.id}`}
            class="text-sm no-underline text-navy/60 hover:text-gold transition-colors"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
