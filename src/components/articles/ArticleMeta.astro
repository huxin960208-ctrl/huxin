---
import { formatReadingTime, getReadingTime } from '../../utils/readingTime';
import { getCategoryTitle, getCategoryUrl } from '../../utils/urlUtils';
import type { Category } from '../../types';

export interface Props {
  pubDate: Date;
  category: Category;
  readingTime?: number;
  author?: string;
}

const { pubDate, category, author } = Astro.props;
const plainText = await Astro.slots.render('default');
const readingTime = Astro.props.readingTime ?? getReadingTime(plainText || '');
---

<div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted mb-4">
  <a
    href={getCategoryUrl(category)}
    class="tag bg-primary/10 text-primary no-underline hover:bg-primary/20 transition-colors"
  >
    {getCategoryTitle(category)}
  </a>
  <time datetime={pubDate.toISOString()} class="flex items-center gap-1">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
  </time>
  <span class="flex items-center gap-1">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    {formatReadingTime(readingTime)}
  </span>
  {author && (
    <span class="flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      {author}
    </span>
  )}
</div>
