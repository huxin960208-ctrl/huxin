---
import { getCategoryTitle } from '../../utils/urlUtils';
import type { Category } from '../../types';

export interface Props {
  pubDate: Date;
  category: Category;
  author?: string;
}

const { pubDate, category, author } = Astro.props;
---

<div class="flex items-center gap-3 text-xs text-muted font-label">
  <span class="text-gold uppercase tracking-wider">{getCategoryTitle(category)}</span>
  <span aria-hidden="true">/</span>
  <time datetime={pubDate.toISOString()}>
    {pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
  </time>
  {author && (
    <>
      <span aria-hidden="true">/</span>
      <span>{author}</span>
    </>
  )}
</div>
