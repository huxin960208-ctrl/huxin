---
import { slugify } from '../../utils/urlUtils';
export interface Props { faqs: { question: string; answer: string }[]; }
const { faqs } = Astro.props;
if (!faqs || faqs.length === 0) return;
---

<section class="my-10" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="text-2xl md:text-3xl mt-14 mb-8">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {faqs.map(faq => {
      const qId = slugify(`faq-${faq.question}`);
      return (
        <details class="group bg-slate-50 border border-slate-200 rounded-xl p-5 cursor-pointer hover:border-slate-300 transition-colors">
          <summary id={qId} class="text-base font-semibold text-slate-900 list-none flex items-center justify-between gap-4 cursor-pointer [&::-webkit-details-marker]:hidden">
            {faq.question}
            <svg class="w-5 h-5 flex-shrink-0 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="mt-3 text-slate-600 leading-relaxed"><p class="mb-0 text-base">{faq.answer}</p></div>
        </details>
      );
    })}
  </div>
</section>
