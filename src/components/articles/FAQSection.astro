---
import { slugify } from '../../utils/urlUtils';

export interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;

if (!faqs || faqs.length === 0) return;
---

<section class="my-10" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="border-b border-border pb-2">Frequently Asked Questions</h2>
  <div class="space-y-4 mt-6">
    {faqs.map((faq) => {
      const qId = slugify(`faq-${faq.question}`);
      return (
        <details class="group bg-white border border-border rounded-lg p-4 cursor-pointer">
          <summary
            id={qId}
            class="font-semibold text-primary list-none flex items-center justify-between gap-4 [&::-webkit-details-marker]:hidden"
          >
            {faq.question}
            <svg
              class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="mt-3 text-muted text-sm md:text-base leading-relaxed">
            <p>{faq.answer}</p>
          </div>
        </details>
      );
    })}
  </div>
</section>
