---
import { slugify } from '../../utils/urlUtils';

export interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;

if (!faqs || faqs.length === 0) return;
---

<section class="my-10" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="border-b border-border pb-3">Frequently Asked Questions</h2>
  <div class="mt-5 space-y-3">
    {faqs.map((faq) => {
      const qId = slugify(`faq-${faq.question}`);
      return (
        <details class="group bg-cream/30 border border-border p-4 cursor-pointer">
          <summary
            id={qId}
            class="text-sm font-medium text-navy list-none flex items-center justify-between gap-4 cursor-pointer [&::-webkit-details-marker]:hidden"
          >
            {faq.question}
            <svg class="w-4 h-4 flex-shrink-0 text-muted group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="mt-3 text-sm text-muted leading-relaxed">
            <p class="mb-0">{faq.answer}</p>
          </div>
        </details>
      );
    })}
  </div>
</section>
