---
import { getArticleUrl, truncate } from '../../utils/urlUtils';
import ArticleMeta from './ArticleMeta.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { data, slug, body } = article;
---

<div class="card border-primary/20 bg-gradient-to-br from-primary/5 to-surface">
  <div class="flex flex-col md:flex-row gap-6 items-start">
    {data.featuredImage && (
      <a href={getArticleUrl(slug)} class="block flex-shrink-0 w-full md:w-64">
        <img
          src={data.featuredImage}
          alt={data.featuredImageAlt ?? data.title}
          class="w-full h-48 md:h-40 object-cover rounded-lg"
          loading="eager"
          width="512"
          height="256"
        />
      </a>
    )}
    <div class="flex-1">
      <span class="inline-block bg-accent text-white text-xs px-2 py-0.5 rounded-full font-semibold mb-2 uppercase tracking-wide">
        Featured
      </span>
      <ArticleMeta
        pubDate={data.pubDate}
        category={data.category}
        author={data.author}
      >
        {body.slice(0, 100)}
      </ArticleMeta>
      <h2 class="text-xl md:text-2xl mt-1 mb-2">
        <a href={getArticleUrl(slug)} class="no-underline hover:text-primary-light transition-colors text-primary">
          {data.title}
        </a>
      </h2>
      <p class="text-muted">{truncate(data.description, 200)}</p>
    </div>
  </div>
</div>
