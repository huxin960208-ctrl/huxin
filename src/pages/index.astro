---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';
import ArticleCard from '../components/articles/ArticleCard.astro';
import { CATEGORIES, CATEGORY_MAP, SITE, type Category } from '../types';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featured = sorted.find((a) => a.data.isFeatured) ?? sorted[0];

function getLatest(cat: Category) {
  return sorted.filter((a) => a.data.category === cat).slice(0, 3);
}
---

<BaseLayout
  title={SITE.tagline}
  description="Free, comprehensive guides on personal injury law."
  canonicalURL={SITE.url}
>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-accent/20 via-transparent to-transparent"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-slate-700/30 via-transparent to-transparent"></div>
    <div class="relative container-wide py-24 md:py-36">
      <div class="max-w-3xl">
        <span class="inline-block text-accent text-xs font-semibold uppercase tracking-[0.2em] mb-6 bg-white/5 px-4 py-1.5 rounded-full border border-white/10">Personal Injury Law Resource</span>
        <h1 class="text-white text-4xl md:text-6xl lg:text-7xl font-bold leading-[1.05] mb-8 text-balance">
          {SITE.tagline}
        </h1>
        <p class="text-slate-300 text-lg md:text-xl leading-relaxed max-w-xl mb-10">
          In-depth, expertly researched guides on car accidents, slip and fall,
          medical malpractice, workplace injuries, and wrongful death.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/articles" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-slate-900 font-semibold px-6 py-3.5 rounded-xl no-underline transition-all duration-200 hover:scale-105 text-sm">
            Explore Insights
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#practices" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/15 text-white font-medium px-6 py-3.5 rounded-xl no-underline transition-all duration-200 backdrop-blur-sm border border-white/10 text-sm">
            Practice Areas
          </a>
        </div>
      </div>
    </div>
    <!-- Bottom gradient fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Practice Areas Grid -->
  <section id="practices" class="container-wide py-20 md:py-28">
    <div class="text-center mb-14">
      <span class="section-badge mb-4">Practice Areas</span>
      <h2 class="text-3xl md:text-5xl mt-4">Explore by Category</h2>
      <p class="text-slate-500 text-lg max-w-xl mx-auto mt-4">In-depth coverage across every major personal injury practice area</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
      {CATEGORIES.map((cat) => {
        const info = CATEGORY_MAP[cat];
        const count = sorted.filter((a) => a.data.category === cat).length;
        return (
          <a
            href={`/categories/${cat}`}
            class="group relative bg-white border border-slate-200 rounded-2xl p-6 no-underline hover:border-accent/40 hover:shadow-xl hover:shadow-slate-900/5 transition-all duration-300 hover:-translate-y-1"
          >
            <div class="text-3xl mb-4">{info.icon}</div>
            <h3 class="text-base font-bold text-slate-900 mb-2 group-hover:text-accent-dark transition-colors">{info.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-0 line-clamp-2">{info.description}</p>
            <div class="mt-4 flex items-center gap-1 text-xs font-semibold text-accent-dark opacity-0 group-hover:opacity-100 transition-opacity">
              {count} articles <span class="ml-0.5">&rarr;</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Featured Article -->
  {featured && (
    <section class="bg-slate-50 border-y border-slate-200">
      <div class="container-wide py-20 md:py-28">
        <div class="text-center mb-12">
          <span class="section-badge">Featured</span>
          <h2 class="text-3xl md:text-5xl mt-4">{featured.data.title}</h2>
          <p class="text-slate-500 text-lg max-w-2xl mx-auto mt-4">{featured.data.description}</p>
          <a href={`/articles/${featured.slug}`} class="inline-flex items-center gap-2 mt-6 bg-slate-900 hover:bg-slate-800 text-white font-semibold px-6 py-3 rounded-xl no-underline transition-all duration-200 text-sm">
            Read Full Article
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Latest Articles by Category -->
  {CATEGORIES.map((cat, i) => {
    const info = CATEGORY_MAP[cat];
    const latest = getLatest(cat);
    if (latest.length === 0) return null;
    return (
      <section class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
        <div class="container-wide py-16 md:py-20">
          <div class="flex items-end justify-between mb-10">
            <div>
              <h2 class="text-2xl md:text-4xl mt-0 mb-2">{info.title}</h2>
              <p class="text-slate-500 text-base mb-0">{info.description}</p>
            </div>
            <a href={`/categories/${cat}`} class="hidden md:inline-flex items-center gap-1 text-sm font-semibold text-accent-dark no-underline hover:text-accent transition-colors flex-shrink-0">
              View all <span>&rarr;</span>
            </a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {latest.map((article) => (
              <ArticleCard article={article} />
            ))}
          </div>
        </div>
      </section>
    );
  })}
</BaseLayout>
