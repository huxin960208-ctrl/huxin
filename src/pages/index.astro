---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';
import ArticleCard from '../components/articles/ArticleCard.astro';
import FeaturedArticle from '../components/articles/FeaturedArticle.astro';
import { CATEGORIES, CATEGORY_MAP, SITE, type Category } from '../types';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featuredArticle = sortedArticles.find((a) => a.data.isFeatured) ?? sortedArticles[0];

function getLatest(cat: Category) {
  return sortedArticles.filter((a) => a.data.category === cat).slice(0, 2);
}
---

<BaseLayout
  title={SITE.tagline}
  description="Free, comprehensive guides on personal injury law. Learn about car accident settlements, slip and fall claims, medical malpractice, workplace injuries, and wrongful death."
  canonicalURL={SITE.url}
>

  <!-- Hero -->
  <section class="bg-cream border-b border-border">
    <div class="container-wide py-20 md:py-28">
      <div class="max-w-3xl">
        <div class="decorative-line mb-6"></div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl text-navy leading-tight mb-5">
          {SITE.tagline}
        </h1>
        <p class="text-base md:text-lg text-muted leading-relaxed max-w-xl mb-8">
          Free, in-depth guides on car accidents, slip and fall, medical malpractice,
          workplace injuries, and wrongful death claims.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/articles" class="inline-block bg-navy text-white font-label text-sm uppercase tracking-wider px-6 py-3 no-underline hover:bg-navy-light transition-colors">
            View All Insights
          </a>
          <a href="#practices" class="inline-block bg-white text-navy border border-border font-label text-sm uppercase tracking-wider px-6 py-3 no-underline hover:border-navy/30 transition-colors">
            Practice Areas
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Practice Areas -->
  <section id="practices" class="container-wide py-16 md:py-20">
    <div class="section-label">Practice Areas</div>
    <h2 class="text-2xl md:text-3xl text-navy mb-10">How We Can Help</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
      {CATEGORIES.map((cat) => {
        const info = CATEGORY_MAP[cat];
        const count = sortedArticles.filter((a) => a.data.category === cat).length;
        return (
          <a
            href={`/categories/${cat}`}
            class="group bg-white p-8 md:p-10 no-underline hover:bg-cream/50 transition-colors"
          >
            <div class="decorative-line mb-5 group-hover:w-16 transition-all duration-300"></div>
            <h3 class="text-lg md:text-xl text-navy mb-2 group-hover:text-gold transition-colors">{info.title}</h3>
            <p class="text-sm text-muted leading-relaxed mb-0">{info.description}</p>
            <span class="inline-block mt-4 text-xs uppercase tracking-wider text-muted group-hover:text-navy transition-colors font-label">
              {count} {count === 1 ? 'Article' : 'Articles'}
            </span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Featured Insight -->
  {featuredArticle && (
    <section class="bg-cream border-y border-border">
      <div class="container-wide py-16 md:py-20">
        <div class="section-label">Featured Insight</div>
        <FeaturedArticle article={featuredArticle} />
      </div>
    </section>
  )}

  <!-- Latest per Practice Area -->
  <div class="container-wide py-16 md:py-20">
    {CATEGORIES.map((cat, i) => {
      const info = CATEGORY_MAP[cat];
      const latest = getLatest(cat);
      if (latest.length === 0) return null;
      return (
        <section class={i > 0 ? 'mt-16 pt-16 border-t border-border' : ''}>
          <div class="flex items-baseline justify-between mb-8">
            <div>
              <h2 class="text-xl md:text-2xl text-navy mb-1">{info.title}</h2>
              <p class="text-sm text-muted mb-0">{info.description}</p>
            </div>
            <a
              href={`/categories/${cat}`}
              class="font-label text-xs uppercase tracking-wider text-navy/60 no-underline hover:text-gold transition-colors flex-shrink-0"
            >
              View All &rarr;
            </a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {latest.map((article) => (
              <ArticleCard article={article} />
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
