---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { SITE } from '../types';
---

<BaseLayout title="Page Not Found" description="The page does not exist." canonicalURL={`${SITE.url}/404`} noindex={true}>
  <div class="container-narrow py-24 md:py-32 text-center">
    <p class="text-8xl md:text-9xl font-display font-bold text-slate-200 mb-4">404</p>
    <h1 class="text-2xl md:text-3xl text-slate-900 mb-3">Page Not Found</h1>
    <p class="text-slate-500 mb-8 max-w-sm mx-auto">The page you're looking for doesn't exist or has been moved.</p>
    <div class="flex gap-4 justify-center">
      <a href="/" class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold px-5 py-3 rounded-xl no-underline transition-all text-sm">Back Home</a>
      <a href="/articles" class="inline-flex items-center gap-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium px-5 py-3 rounded-xl no-underline transition-all text-sm">View Insights</a>
    </div>
  </div>
</BaseLayout>
