---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { SITE } from '../types';
---

<BaseLayout
  title="Page Not Found"
  description="The page you are looking for does not exist."
  canonicalURL={`${SITE.url}/404`}
  noindex={true}
>
  <div class="container-narrow py-20 md:py-28 text-center">
    <p class="text-6xl md:text-7xl text-gold/40 font-heading mb-6">404</p>
    <h1 class="text-xl md:text-2xl text-navy mb-3">Page Not Found</h1>
    <p class="text-sm text-muted mb-8 max-w-sm mx-auto">
      The page you are looking for may have been moved or no longer exists.
    </p>
    <div class="flex gap-4 justify-center">
      <a href="/" class="inline-block bg-navy text-white font-label text-xs uppercase tracking-wider px-5 py-2.5 no-underline hover:bg-navy-light transition-colors">Home</a>
      <a href="/articles" class="inline-block bg-white text-navy border border-border font-label text-xs uppercase tracking-wider px-5 py-2.5 no-underline hover:border-navy/30 transition-colors">Insights</a>
    </div>
  </div>
</BaseLayout>
