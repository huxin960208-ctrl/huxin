---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import TableOfContents from '../../components/articles/TableOfContents.astro';
import ArticleMeta from '../../components/articles/ArticleMeta.astro';
import FAQSection from '../../components/articles/FAQSection.astro';
import KeyTakeaways from '../../components/articles/KeyTakeaways.astro';
import AuthorBio from '../../components/articles/AuthorBio.astro';
import InArticleAd from '../../components/ads/InArticleAd.astro';
import ArticleSchema from '../../components/seo/ArticleSchema.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import { getCategoryTitle, getCategoryUrl, getArticleUrl } from '../../utils/urlUtils';
import { SITE } from '../../types';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map(article => ({ params: { slug: article.slug }, props: { article } }));
}

const { article } = Astro.props;
const { data, body, slug } = article as CollectionEntry<'articles'>;
const articleContent = await article.render();
const headingMatches = body.match(/^#{2,3}\s+.+$/gm) ?? [];
const headings = headingMatches.map((h: string) => {
  const depth = h.startsWith('###') ? 3 : 2;
  const text = h.replace(/^#{2,3}\s+/, '');
  return { depth, text };
});
const articleUrl = getArticleUrl(slug);
const fullUrl = `${SITE.url}${articleUrl}`;
const breadcrumbItems = [
  { name: 'Insights', url: '/articles' },
  { name: getCategoryTitle(data.category), url: getCategoryUrl(data.category) },
  { name: data.title, url: articleUrl },
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonicalURL={fullUrl}
  ogType="article"
  ogImage={data.featuredImage ? `${SITE.url}${data.featuredImage}` : undefined}
>
  <ArticleSchema title={data.title} description={data.description} url={articleUrl} pubDate={data.pubDate} updatedDate={data.updatedDate} author={data.author} featuredImage={data.featuredImage} category={data.category} />
  {data.faq && data.faq.length > 0 && <FAQSchema faqs={data.faq} />}
  <BreadcrumbSchema items={breadcrumbItems} />

  <article class="py-12 md:py-16">
    <div class="container-narrow">
      <Breadcrumbs items={[{ label: 'Insights', href: '/articles' }, { label: getCategoryTitle(data.category), href: getCategoryUrl(data.category) }, { label: data.title }]} />

      <header class="mb-10">
        <h1 class="text-3xl md:text-4xl lg:text-5xl leading-tight mb-4">{data.title}</h1>
        <ArticleMeta pubDate={data.pubDate} category={data.category} author={data.author} />
      </header>

      {data.featuredImage && <img src={data.featuredImage} alt={data.featuredImageAlt ?? data.title} class="w-full rounded-2xl mb-10 shadow-lg" loading="eager" width="800" height="400" />}

      <div class="flex gap-10">
        {headings.length > 3 && (
          <aside class="hidden lg:block w-56 flex-shrink-0">
            <TableOfContents headings={headings} />
          </aside>
        )}
        <div class="flex-1 min-w-0">
          {headings.length > 3 && <div class="lg:hidden mb-8"><TableOfContents headings={headings} /></div>}
          {data.keyTakeaways && data.keyTakeaways.length > 0 && <KeyTakeaways takeaways={data.keyTakeaways} />}
          <div class="article-body"><articleContent.Content /></div>
          <InArticleAd />
          {data.faq && data.faq.length > 0 && <FAQSection faqs={data.faq} />}
          {data.faq && data.faq.length > 0 && <InArticleAd />}
          <AuthorBio author={data.author} bio={data.authorBio} />
        </div>
      </div>

      <footer class="mt-16 pt-10 border-t border-slate-200">
        <h2 class="text-2xl mb-8">More {getCategoryTitle(data.category)} Insights</h2>
        {
          (async () => {
            const related = (await getCollection('articles', ({ data: d }) => !d.draft && d.category === data.category && d.title !== data.title)).slice(0, 3);
            return related.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                {related.map(rel => (
                  <article class="bg-slate-50 border border-slate-200 rounded-xl p-5 hover:border-slate-300 transition-colors">
                    <a href={getArticleUrl(rel.slug)} class="no-underline"><h3 class="text-base font-bold text-slate-900 hover:text-accent-dark transition-colors mb-1">{rel.data.title}</h3></a>
                    <p class="text-xs text-slate-500 mb-0">{rel.data.description.slice(0, 100)}...</p>
                  </article>
                ))}
              </div>
            ) : null;
          })()
        }
      </footer>
    </div>
  </article>
</BaseLayout>
