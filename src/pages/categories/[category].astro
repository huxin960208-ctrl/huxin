---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import Pagination from '../../components/navigation/Pagination.astro';
import CategoryNav from '../../components/navigation/CategoryNav.astro';
import ArticleCard from '../../components/articles/ArticleCard.astro';
import { CATEGORIES, CATEGORY_MAP, SITE, type Category } from '../../types';

export async function getStaticPaths() {
  return CATEGORIES.map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
const ARTICLES_PER_PAGE = 9;

if (!CATEGORIES.includes(category as Category)) {
  return Astro.redirect('/404');
}

const cat = category as Category;
const info = CATEGORY_MAP[cat];

const all = await getCollection('articles', ({ data }) => !data.draft && data.category === cat);
const sorted = all.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const totalPages = Math.ceil(sorted.length / ARTICLES_PER_PAGE);
const pageArticles = sorted.slice(0, ARTICLES_PER_PAGE);
---

<BaseLayout
  title={`${info.title} — Insights & Resources`}
  description={info.description}
  canonicalURL={`${SITE.url}/categories/${cat}`}
>
  <div class="container-narrow py-10 md:py-14">
    <Breadcrumbs items={[{ label: 'Categories', href: '/categories' }, { label: info.title }]} />

    <h1 class="text-2xl md:text-3xl mb-2">{info.title}</h1>
    <p class="text-muted mb-6 max-w-xl">{info.description}</p>

    <CategoryNav categories={CATEGORIES as unknown as Category[]} selected={cat} />

    {pageArticles.length > 0 ? (
      <div class="mt-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {pageArticles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
        <Pagination currentPage={1} totalPages={totalPages} baseUrl={`/categories/${cat}`} />
      </div>
    ) : (
      <div class="text-center py-16 mt-8">
        <h2 class="text-xl text-muted font-heading">No articles yet</h2>
        <p class="text-muted mt-2">Check back soon or browse other categories.</p>
      </div>
    )}
  </div>
</BaseLayout>
