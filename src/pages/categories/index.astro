---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import { CATEGORIES, CATEGORY_MAP, SITE, type Category } from '../../types';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const counts = Object.fromEntries(
  CATEGORIES.map((cat) => [cat, articles.filter((a) => a.data.category === cat).length])
) as Record<Category, number>;
---

<BaseLayout
  title="Practice Areas"
  description="Browse our personal injury guides by practice area."
  canonicalURL={`${SITE.url}/categories`}
>
  <div class="container-narrow py-10 md:py-14">
    <Breadcrumbs items={[{ label: 'Practice Areas' }]} />

    <h1 class="text-2xl md:text-3xl mb-2">Practice Areas</h1>
    <p class="text-muted mb-10 max-w-xl">
      Select a practice area to explore our in-depth guides and insights.
    </p>

    <div class="space-y-4">
      {CATEGORIES.map((cat) => {
        const info = CATEGORY_MAP[cat];
        const count = counts[cat];
        return (
          <a
            href={`/categories/${cat}`}
            class="group block bg-white border border-border p-6 md:p-8 no-underline hover:border-navy/20 hover:bg-cream/30 transition-all"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-lg md:text-xl text-navy group-hover:text-gold transition-colors mb-1">{info.title}</h2>
                <p class="text-sm text-muted leading-relaxed mb-0">{info.description}</p>
              </div>
              <span class="font-label text-xs uppercase tracking-wider text-muted group-hover:text-navy flex-shrink-0 mt-1">
                {count} {count === 1 ? 'Article' : 'Articles'} &rarr;
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
