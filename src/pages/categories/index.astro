---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import { CATEGORIES, CATEGORY_MAP, SITE, type Category } from '../../types';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const articleCounts = Object.fromEntries(
  CATEGORIES.map((cat) => [cat, articles.filter((a) => a.data.category === cat).length])
) as Record<Category, number>;
---

<BaseLayout
  title="Personal Injury Categories"
  description="Browse our personal injury guides by category: car accidents, slip and fall, medical malpractice, workplace injuries, and wrongful death."
  canonicalURL={`${SITE.url}/categories`}
>
  <div class="container-main py-8 md:py-12">
    <Breadcrumbs items={[{ label: 'Categories' }]} />

    <h1 class="text-3xl md:text-4xl mb-2">Browse by Category</h1>
    <p class="text-muted mb-8 max-w-2xl">
      Select a category below to find in-depth guides and resources on specific types of
      personal injury claims.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {CATEGORIES.map((cat) => {
        const info = CATEGORY_MAP[cat];
        const count = articleCounts[cat];
        return (
          <a
            href={`/categories/${cat}`}
            class="card no-underline group text-left block"
          >
            <div class="text-4xl mb-3">{info.icon}</div>
            <h2 class="text-xl mb-2 group-hover:text-primary-light transition-colors">{info.title}</h2>
            <p class="text-sm text-muted mb-3">{info.description}</p>
            <span class="text-sm font-medium text-primary-light">
              {count} {count === 1 ? 'article' : 'articles'} &rarr;
            </span>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
