---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import { CATEGORIES, CATEGORY_MAP, SITE, type Category } from '../../types';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const articleCounts = Object.fromEntries(
  CATEGORIES.map((cat) => [cat, articles.filter((a) => a.data.category === cat).length])
) as Record<Category, number>;
---

<BaseLayout
  title="Personal Injury Categories"
  description="Browse our personal injury guides by category: car accidents, slip and fall, medical malpractice, workplace injuries, and wrongful death."
  canonicalURL={`${SITE.url}/categories`}
>
  <div class="container-main py-8 md:py-12">
    <Breadcrumbs items={[{ label: 'Categories' }]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-2">Browse by Category</h1>
    <p class="text-muted text-sm md:text-base mb-8 max-w-2xl">
      Select a category below to find in-depth guides on specific types of personal injury claims.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {CATEGORIES.map((cat) => {
        const info = CATEGORY_MAP[cat];
        const count = articleCounts[cat];
        return (
          <a
            href={`/categories/${cat}`}
            class="group flex items-start gap-4 bg-white rounded-lg border border-border p-5 md:p-6 no-underline hover:border-primary/20 hover:shadow-sm transition-all duration-200"
          >
            <span class="text-xl leading-none flex-shrink-0">{info.icon}</span>
            <div class="min-w-0">
              <h2 class="text-lg font-bold text-primary group-hover:text-primary-light transition-colors mb-1">{info.title}</h2>
              <p class="text-sm text-muted leading-relaxed mb-2">{info.description}</p>
              <span class="text-xs font-medium text-primary-light">
                {count} {count === 1 ? 'article' : 'articles'} &rarr;
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
